# =============================================================================
# .gitignore — Natural Tecnologia / nt-usina
# =============================================================================

# -----------------------------------------------------------------------------
# Variáveis de ambiente — nunca commitar valores reais
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Dependências (geradas por package managers)
# -----------------------------------------------------------------------------
vendor/
node_modules/

# -----------------------------------------------------------------------------
# Build e artefatos compilados
# -----------------------------------------------------------------------------
dist/
build/
public/hot
public/storage
storage/*.key

# -----------------------------------------------------------------------------
# Cache e logs da aplicação
# -----------------------------------------------------------------------------
storage/logs/
bootstrap/cache/
*.log
!docs/pipeline.log

# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Sistema operacional
# -----------------------------------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store

# -----------------------------------------------------------------------------
# Testes
# -----------------------------------------------------------------------------
.phpunit.result.cache
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Python (se usado na stack)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
*.egg-info/
